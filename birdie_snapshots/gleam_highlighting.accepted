<span class="hl-punctuation">}</span>

<span class="hl-keyword">pub</span> <span class="hl-keyword">fn</span> <span class="hl-function">main</span><span class="hl-punctuation">(</span><span class="hl-punctuation">)</span> <span class="hl-punctuation">{</span>
  <span class="hl-keyword">let</span> user <span class="hl-operator">=</span> <span class="hl-type">User</span><span class="hl-punctuation">(</span><span class="hl-string">&quot;Lucy&quot;</span><span class="hl-punctuation">,</span> <span class="hl-number">30</span><span class="hl-punctuation">)</span>
