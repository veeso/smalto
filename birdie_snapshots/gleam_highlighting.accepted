  <span class="hl-module">list</span><span class="hl-punctuation">.</span><span class="hl-function">map</span><span class="hl-punctuation">(</span><span class="hl-punctuation">[</span><span class="hl-number">1</span><span class="hl-punctuation">,</span> <span class="hl-number">2</span><span class="hl-punctuation">,</span> <span class="hl-number">3</span><span class="hl-punctuation">]</span><span class="hl-punctuation">,</span> <span class="hl-keyword">fn</span><span class="hl-punctuation">(</span>n<span class="hl-punctuation">)</span> <span class="hl-punctuation">{</span> n <span class="hl-operator">*</span> <span class="hl-number">2</span> <span class="hl-punctuation">}</span><span class="hl-punctuation">)</span>
  <span class="hl-operator">|&gt;</span> io<span class="hl-punctuation">.</span>debug
