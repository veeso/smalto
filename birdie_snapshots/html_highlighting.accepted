<span class="smalto-tag">&lt;head&gt;</span><span class="smalto-tag">&lt;title&gt;</span>Test<span class="smalto-tag">&lt;/title&gt;</span><span class="smalto-tag">&lt;/head&gt;</span>
<span class="smalto-tag">&lt;body&gt;</span>
  <span class="smalto-tag">&lt;h1 class=&quot;title&quot;&gt;</span>Hello<span class="smalto-tag">&lt;/h1&gt;</span>
