<span class="hl-comment">// Comment</span>
<span class="hl-keyword">const</span> <span class="hl-function">greet</span> <span class="hl-operator">=</span> <span class="hl-punctuation">(</span><span class="hl-parameter">name</span><span class="hl-punctuation">)</span> <span class="hl-operator">=&gt;</span> <span class="hl-punctuation">{</span>
  <span class="hl-keyword">return</span> <span class="hl-string">&#39;Hello&#39;</span><span class="hl-punctuation">;</span>
<span class="hl-punctuation">}</span><span class="hl-punctuation">;</span>
console<span class="hl-punctuation">.</span><span class="hl-function">log</span><span class="hl-punctuation">(</span><span class="hl-function">greet</span><span class="hl-punctuation">(</span><span class="hl-string">&#39;world&#39;</span><span class="hl-punctuation">)</span><span class="hl-punctuation">)</span><span class="hl-punctuation">;</span>
