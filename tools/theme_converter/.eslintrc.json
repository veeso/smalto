{
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2024": true
  },
  "rules": {
    "import/extensions": ["error", "ignorePackages"],
    "import/no-unresolved": "off",
    "import/prefer-default-export": "off",
    "implicit-arrow-linebreak": "off",
    "operator-linebreak": "off",
    "no-console": "off",
    "object-curly-newline": "off"
  }
}
